# ── Infoblox NOC Dashboard — environment ──────────────────────────────
# Copy to `.env` and fill in. NEVER commit your real `.env`.
#   cp .env.example .env

# Single-key mode: set this to skip the in-app vault setup.
# Leave blank to use the encrypted vault (set a passphrase + keys in the browser).
# Get a key: https://csp.infoblox.com → top-right user menu → User API Keys → Create.
INFOBLOX_API_KEY=

# Infoblox portal base URL (rarely changed).
INFOBLOX_URL=https://csp.infoblox.com

# ── LLM for the natural-language query box (OPTIONAL) ──────────────────
# Leave blank to disable the AI query box; the rest of the dashboard works.
#
# Default provider: Groq (free tier — see README). Get a key:
#   https://console.groq.com → API Keys → Create API Key
GROQ_API_KEY=

# Advanced — point at ANY OpenAI-compatible provider without code edits.
# LLM_API_KEY overrides GROQ_API_KEY if set. Leave LLM_BASE_URL blank for Groq.
#   Groq (default):  LLM_MODEL=qwen/qwen3-32b   LLM_BASE_URL=(blank)
#   OpenAI:          LLM_MODEL=gpt-4o-mini       LLM_BASE_URL=https://api.openai.com/v1
#   Together:        LLM_MODEL=meta-llama/...    LLM_BASE_URL=https://api.together.xyz/v1
#   Local (Ollama):  LLM_MODEL=llama3.1          LLM_BASE_URL=http://host.docker.internal:11434/v1
# LLM_API_KEY=
# LLM_MODEL=qwen/qwen3-32b
# LLM_BASE_URL=

# Account switching: the sidebar shows a portal-style "Switch account" menu
# automatically when this API key's user belongs to more than one CSP account
# (interactive user keys). Service keys are bound to a single account.

# ── Encrypted vault (auto-unlock after upgrades) ──────────────────────
# Only used in VAULT MODE (when INFOBLOX_API_KEY above is blank). The vault
# itself lives in the mounted volume (-v noc-vault:/vault) and survives
# upgrades; these only spare you re-typing the passphrase in the browser.
# VAULT_DIR=/vault                       # where vault.json is stored (default /vault)
#
# Supply the unlock passphrase at boot so the dashboard comes up live with no
# browser step. Keys stay AES-encrypted on disk; whoever can read this secret
# can decrypt the vault, so prefer the *_FILE form (Docker/K8s secret) over the
# raw env var. The file is preferred when both are set.
# VAULT_PASSPHRASE_FILE=/run/secrets/vault_pass
# VAULT_PASSPHRASE=your-vault-passphrase

# Container bind/port (defaults are fine).
# HOST is forced to 0.0.0.0 inside Docker by the Dockerfile.
PORT=8080

# ── docker-compose.yml settings (ignored by run.sh/dev.sh) ────────────
# BIND=127.0.0.1 keeps it loopback; BIND=0.0.0.0 exposes on the LAN (no login!).
BIND=127.0.0.1
# Shared secret for the Watchtower HTTP API (internal network only).
# Override the default: openssl rand -hex 24
WATCHTOWER_TOKEN=noc-local-update-token

# ── secure profile only:  docker compose --profile secure up -d ───────
# TLS + basic-auth reverse proxy (Caddy). Set BIND=127.0.0.1 above so all LAN
# access goes through Caddy, not the dashboard's own port.
HTTPS_BIND=0.0.0.0
HTTPS_PORT=8443
SITE_ADDRESS=:443                 # or your.host.name for a real (non-self-signed) cert
BASIC_AUTH_USER=admin
# Generate: docker run --rm caddy caddy hash-password -p 'yourpassword'
BASIC_AUTH_HASH=

{
  "mcpServers": {
    "InfobloxMCP": {
      "command": "npx",
      "args": [
        "mcp-remote",
        "https://csp.infoblox.com/mcp",
        "--header",
        "Authorization:${AUTH_HEADER}",
        "--auth-timeout",
        "5"
      ],
      "env": {
        "AUTH_HEADER": "${INFOBLOX_API_KEY}"
      }
    }
  }
}
